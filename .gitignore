# =============================================================
#  GRA-MicroAnalyzer — .gitignore
# =============================================================

# ---------------------------
# Python
# ---------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ---------------------------
# Virtual Environments
# ---------------------------
.venv/
venv/
env/
ENV/
ecc_sim/

# ---------------------------
# Distribution / Build
# ---------------------------
build/
dist/
*.egg-info/
*.egg
MANIFEST
*.spec

# ---------------------------
# PyInstaller
# ---------------------------
*.manifest

# ---------------------------
# Jupyter / IPython
# ---------------------------
.ipynb_checkpoints/
*.ipynb

# ---------------------------
# IDE & Editor
# ---------------------------
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.swp
*.swo
*~

# ---------------------------
# Windows
# ---------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ---------------------------
# macOS (协作时备用)
# ---------------------------
.DS_Store
.AppleDouble
.LSOverride

# ---------------------------
# 测试 & 覆盖率
# ---------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover

# ---------------------------
# mypy / 类型检查缓存
# ---------------------------
.mypy_cache/
.dmypy.json
dmypy.json

# ---------------------------
# 日志
# ---------------------------
*.log
logs/

# ---------------------------
# 用户数据 & 临时输出
# ---------------------------
# 不提交任何用户上传的数据集
data/
*.csv
*.xlsx
*.xls

# 导出的图表与结果（本地产物，不入库）
output/
exports/
*.svg
*.pdf
*.png

# ---------------------------
# 项目运行时产生的配置缓存
# ---------------------------
*.json
!pyproject.toml

# ---------------------------
# 打包工具
# ---------------------------
pip-log.txt
pip-delete-this-directory.txt
